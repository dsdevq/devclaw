# DevClaw environment — copy to .env and adjust per host.
#
# Real env vars (shell / systemd / compose) ALWAYS WIN over .env.
# Commented-out lines below show defaults; uncomment + edit to override.
#
# Full reference (purpose of each var): docs/env-vars.md
# Internal tuning (timeouts, breaker thresholds, retry buffers) is code
# constants changed by PR — deliberately not in this file.

# ── Server transport + auth ────────────────────────────────────────────────
#DEVCLAW_TRANSPORT=stdio                  # stdio | http
#DEVCLAW_PORT=8000
#DEVCLAW_HOST=0.0.0.0                     # set 127.0.0.1 to restrict to loopback
#DEVCLAW_TOKEN=                           # bearer-token gate; unset = no auth
# DEVCLAW_DOTENV picks this file's path — must be set in the shell, not here.

# ── State + concurrency ────────────────────────────────────────────────────
#DEVCLAW_DB=./devclaw.db
#DEVCLAW_TICK_SECONDS=10
#DEVCLAW_MAX_CONCURRENT=4
#DEVCLAW_MAX_CONCURRENT_PER_PROGRAM=2
#DEVCLAW_MAX_RETRIES=1
#DEVCLAW_TASK_TIMEOUT_S=1800
#DEVCLAW_VERIFY_TIMEOUT_S=900
#DEVCLAW_SKILL_LIBRARY=/opt/devclaw/skill-library

# ── Engine + cognition backend ─────────────────────────────────────────────
#DEVCLAW_ENGINE=                          # unset=sandbox | host | stub | claude_sdk
#DEVCLAW_COGNITION=claude                 # claude | stub
#DEVCLAW_COGNITION_TIMEOUT_S=180          # default cap (s) for one claude --print cognition call

# ── Model tiering (per-role assignment lives in devclaw/model_tiers.py) ────
#DEVCLAW_MODEL_DEEP=opus
#DEVCLAW_MODEL_STANDARD=sonnet
#DEVCLAW_MODEL_LIGHT=haiku
#DEVCLAW_EXEC_MODEL=claude-sonnet-4-6     # in-sandbox coding agent — full id

# ── Sandbox (auth + resources) ─────────────────────────────────────────────
#DEVCLAW_SANDBOX_IMAGE=devclaw-sandbox:latest
#DEVCLAW_DOCKER_BIN=docker
#DEVCLAW_SANDBOX_MEMORY=2g
#DEVCLAW_SANDBOX_CPUS=2.0
#DEVCLAW_HOST_CLAUDE_DIR=~/.claude
#DEVCLAW_SANDBOX_CLAUDE_ALLOWLIST=.credentials.json,.claude.json
#DEVCLAW_CONTAINER_PATH_PREFIX=           # only when devclaw itself is containerized
#DEVCLAW_HOST_PATH_PREFIX=                # pairs with CONTAINER_PATH_PREFIX
#DEVCLAW_RUNNER_PY=                       # host engine: runner script path
#DEVCLAW_RUNNER_PYTHON=                   # host engine: interpreter for the runner
#DEVCLAW_SKILLS_DIR=/opt/devclaw/skills   # in-sandbox
#DEVCLAW_HOOKS_DIR=/opt/devclaw/hooks     # in-sandbox

# ── Auth (Pro OAuth posture — never an API key) ────────────────────────────
#DEVCLAW_CLAUDE_BIN=claude
#DEVCLAW_TAILSCALE_BIN=tailscale
#DEVCLAW_GITHUB_OWNER=                    # create_repo target; falls back to gh login
# GITHUB_TOKEN / GH_TOKEN — repo push + PR access (or a logged-in gh).
# ANTHROPIC_API_KEY / ANTHROPIC_AUTH_TOKEN are actively stripped — do not set.

# ── Goal layer ──────────────────────────────────────────────────────────────
# automerge / merge_strategy / review_gate / verify_done / autodeploy are
# project-registry overrides now, not env.
#DEVCLAW_GOALS_DIR=~/memory/goals
#DEVCLAW_GOAL_TICK_SECONDS=900
#DEVCLAW_GOAL_EVAL_EVERY=3
#DEVCLAW_GOAL_FIRMING=0                   # migration flag
#DEVCLAW_GOAL_DECOMPOSE=0                 # migration flag
#DEVCLAW_GOAL_INVESTIGATE=1               # migration flag
#DEVCLAW_GOAL_REMOTE_CHECKS=1             # ops kill-switch for remote CI queries
#DEVCLAW_GOAL_NO_PROGRESS_S=21600
#DEVCLAW_GOAL_NOTIFY_URL=
#DEVCLAW_GOAL_PLAIN_SUMMARY=1             # quota lever
#DEVCLAW_NOTIFY_ALTITUDE=owner            # owner | task

# ── Deploy hosting ──────────────────────────────────────────────────────────
#DEVCLAW_DEPLOY_IMAGE=                    # falls back to DEVCLAW_SANDBOX_IMAGE
#DEVCLAW_DEPLOY_PORT_BASE=8200
#DEVCLAW_DEPLOY_PORT_SPAN=200
#DEVCLAW_DEPLOY_MEMORY=512m
#DEVCLAW_DEPLOY_CPUS=1.0
#DEVCLAW_DEPLOY_MAX=5

# ── Trend detection (self-observation) ──────────────────────────────────────
#DEVCLAW_TREND_ENABLED=1
#DEVCLAW_TREND_DISABLE=                   # e.g. R2,H4 — mute individual signals
#DEVCLAW_TREND_HARNESS_SELF_FILE=~/memory/projects/devclaw/trends.md
