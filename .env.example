# DevClaw environment — copy to .env and adjust per host.
#
# Real env vars (shell / systemd / compose) ALWAYS WIN over .env.
# Commented-out lines below show defaults; uncomment + edit to override.
#
# Full reference (purpose of each var): docs/env-vars.md

# ── Server transport + auth ────────────────────────────────────────────────
#DEVCLAW_TRANSPORT=stdio                  # stdio | http
#DEVCLAW_PORT=8000
#DEVCLAW_HOST=0.0.0.0                     # set 127.0.0.1 to restrict to loopback
#DEVCLAW_TOKEN=                           # bearer-token gate; unset = no auth

# ── State + concurrency ────────────────────────────────────────────────────
#DEVCLAW_DB=./devclaw.db
#DEVCLAW_SQLITE_BUSY_TIMEOUT_MS=5000
#DEVCLAW_TICK_SECONDS=10
#DEVCLAW_MAX_CONCURRENT=4
#DEVCLAW_MAX_CONCURRENT_PER_PROGRAM=2
#DEVCLAW_MAX_RETRIES=1
#DEVCLAW_TASK_TIMEOUT_S=1800
#DEVCLAW_VERIFY_TIMEOUT_S=900
#DEVCLAW_RATE_LIMIT_PAUSE_S=1800
#DEVCLAW_RATE_LIMIT_MAX_PAUSE_S=3600

# ── Engine selection ───────────────────────────────────────────────────────
#DEVCLAW_ENGINE=                          # unset | host | stub | claude_sdk
#DEVCLAW_EXEC_MODEL=claude-sonnet-4-6     # full id; set claude-opus-4-8 for hard runs
#DEVCLAW_AGENT_TIMEOUT_S=1800             # claude-sdk engine only
#DEVCLAW_PLANNER_TIMEOUT_MS=90000

# ── Sandbox (auth + resources) ─────────────────────────────────────────────
#DEVCLAW_SANDBOX_IMAGE=devclaw-sandbox:latest
#DEVCLAW_DOCKER_BIN=docker
#DEVCLAW_SANDBOX_MEMORY=2g
#DEVCLAW_SANDBOX_CPUS=2.0
#DEVCLAW_HOST_CLAUDE_DIR=~/.claude
#DEVCLAW_SANDBOX_CLAUDE_ALLOWLIST=.credentials.json,.claude.json
#DEVCLAW_CONTAINER_PATH_PREFIX=           # set only when devclaw itself runs in a container
#DEVCLAW_HOST_PATH_PREFIX=                # pair with the above
#DEVCLAW_RUNNER_PY=                       # default: resolved against repo
#DEVCLAW_RUNNER_PYTHON=                   # default: derived

# ── Auth (Pro OAuth posture; API keys are actively refused) ────────────────
#DEVCLAW_CLAUDE_BIN=claude
#DEVCLAW_TAILSCALE_BIN=tailscale
#GITHUB_TOKEN=                            # git push + PR access (or use a logged-in `gh`)
#GH_TOKEN=
#DEVCLAW_GITHUB_OWNER=                    # falls back to `gh`'s active login

# ── Goal layer ─────────────────────────────────────────────────────────────
#DEVCLAW_GOALS_DIR=~/memory/goals
#DEVCLAW_GOAL_TICK_SECONDS=900
#DEVCLAW_GOAL_EVAL_EVERY=3                # 0 → only at the done-gate
#DEVCLAW_GOAL_VERIFY_DONE=1
#DEVCLAW_GOAL_NO_PROGRESS_S=21600         # 0 disables
#DEVCLAW_GOAL_NOTIFY_URL=
#DEVCLAW_GOAL_INVESTIGATE=1
#DEVCLAW_GOAL_AUTODEPLOY=1                # 0 disables auto-deploy on achieved
#DEVCLAW_GOAL_AUTOMERGE=0
#DEVCLAW_GOAL_MERGE_STRATEGY=squash       # squash | merge | rebase
#DEVCLAW_GOAL_PLAIN_SUMMARY=1
#DEVCLAW_NOTIFY_ALTITUDE=owner            # owner | task

# ── Pre-PR review gate ─────────────────────────────────────────────────────
#DEVCLAW_REVIEW_GATE=1                    # 0 disables (escape hatch + quota lever)
#DEVCLAW_REVIEW_MODEL=sonnet
#DEVCLAW_REVIEW_MAX_DIFF_CHARS=60000

# ── Model tiering ──────────────────────────────────────────────────────────
#DEVCLAW_PLANNER_MODEL=opus
#DEVCLAW_GRILL_MODEL=sonnet               # the scope_grill MCP tool's cognition
#DEVCLAW_JUDGE_MODEL=haiku
# (DEVCLAW_EXEC_MODEL is up in "Engine selection")
#DEVCLAW_GOAL_PLANNER_MODEL=sonnet
#DEVCLAW_GOAL_EVAL_MODEL=sonnet
#DEVCLAW_GOAL_SUMMARY_MODEL=haiku

# ── Deploy hosting ─────────────────────────────────────────────────────────
#DEVCLAW_DEPLOY_IMAGE=                    # falls back to DEVCLAW_SANDBOX_IMAGE
#DEVCLAW_DEPLOY_PORT_BASE=8200
#DEVCLAW_DEPLOY_PORT_SPAN=200
#DEVCLAW_DEPLOY_MEMORY=512m
#DEVCLAW_DEPLOY_CPUS=1.0
#DEVCLAW_DEPLOY_MAX=5

# ── Scope grill (waiter-called MCP tool) ───────────────────────────────────
#DEVCLAW_MAX_GRILL_QUESTIONS=20           # safety cap before the spec is force-finalized

# ── Cognition backend ──────────────────────────────────────────────────────
#DEVCLAW_COGNITION=claude                 # claude (default) | stub (offline harness)
