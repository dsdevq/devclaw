# OS junk
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Local scratch
/tmp/
.cache/
/tmp-workspaces/

# Python
.venv/
*.log

# Runtime state — never belongs in the repo
*.db
*.db-shm
*.db-wal
openhands-runner/.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/

# Anything that looks like personal state should not be in this repo
.env
.env.*
!.env.example
*.local.yaml
auth-profiles.json
*.pem
*.key

# Eval run artifacts (results, not source)
evals/runs/

# Claude Code harness config: track shared skills/hooks/settings,
# keep per-machine bits (settings.local.json, worktrees/) local
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/hooks/
!.claude/rules/
!.claude/agents/
!.claude/commands/

# Console build output — the Vite+React SPA is built at image-build time
# (compose/devclaw-mcp/Dockerfile), not vendored. hatchling force-includes it
# into the wheel via `tool.hatch.build.targets.wheel.artifacts` in pyproject.
devclaw/server/console/dist/

# Real proof baskets may reference private-product internals — keep only the template
evals/baskets/*.json
!evals/baskets/*.example.json
